{
  "AllowedExtensions": [
    ".jpg", ".jpeg", ".png", ".gif", ".bmp",
    ".webp", ".svg", ".tiff", ".tif", ".ico", ".avif",
    ".pdf", ".txt", ".csv"
  ],
  "AllowedMimeTypes": [
    "image/jpeg", "image/png", "image/gif", "image/bmp",
    "image/webp", "image/svg+xml", "image/tiff", "image/x-icon", "image/avif",
    "application/pdf", "text/plain", "text/csv"
  ],
  "MimeTypeExtensionMap": {
    "image/jpeg": ".jpg",
    "image/png": ".png",
    "image/gif": ".gif",
    "image/bmp": ".bmp",
    "image/webp": ".webp",
    "image/svg+xml": ".svg",
    "image/tiff": ".tiff",
    "image/x-icon": ".ico",
    "image/avif": ".avif",
    "application/pdf": ".pdf",
    "text/plain": ".txt",
    "text/csv": ".csv"
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  }
}
